{
  "name": "defang",
  "version": "1.1.0-alpha+dirty",
  "description": "Deploy containerized services to AWS or GCP with Pulumi.",
  "keywords": [
    "category/cloud",
    "category/infrastructure",
    "kind/native",
    "defang",
    "docker",
    "cloud",
    "aws",
    "gcp",
    "ecs",
    "fargate",
    "cloudrun"
  ],
  "homepage": "https://github.com/DefangLabs/pulumi-defang",
  "license": "Apache-2.0",
  "repository": "https://github.com/DefangLabs/pulumi-defang",
  "logoUrl": "https://raw.githubusercontent.com/DefangLabs/pulumi-defang/refs/heads/main/docs/logo.png",
  "pluginDownloadURL": "github://api.github.com/DefangLabs",
  "publisher": "Defang",
  "language": {
    "csharp": {
      "rootNamespace": "DefangLabs"
    },
    "nodejs": {
      "packageName": "@defang-io/pulumi-defang"
    },
    "python": {
      "pyproject": {}
    }
  },
  "config": {},
  "types": {
    "defang:index:AWSConfigInput": {
      "properties": {
        "privateSubnetIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "region": {
          "type": "string"
        },
        "subnetIds": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "vpcId": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "defang:index:CloudRunConfig": {
      "properties": {
        "ingress": {
          "type": "string"
        },
        "launchStage": {
          "type": "string"
        },
        "maxReplicas": {
          "type": "integer"
        }
      },
      "type": "object"
    },
    "defang:index:DeployConfig": {
      "properties": {
        "replicas": {
          "type": "integer"
        },
        "resources": {
          "$ref": "#/types/defang:index:ResourcesConfig"
        }
      },
      "type": "object"
    },
    "defang:index:GCPConfigInput": {
      "properties": {
        "project": {
          "type": "string"
        },
        "region": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "defang:index:HealthCheckConfig": {
      "properties": {
        "intervalSeconds": {
          "type": "integer"
        },
        "retries": {
          "type": "integer"
        },
        "startPeriodSeconds": {
          "type": "integer"
        },
        "test": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "timeoutSeconds": {
          "type": "integer"
        }
      },
      "type": "object"
    },
    "defang:index:PortConfig": {
      "properties": {
        "appProtocol": {
          "type": "string"
        },
        "mode": {
          "type": "string"
        },
        "protocol": {
          "type": "string"
        },
        "target": {
          "type": "integer"
        }
      },
      "type": "object",
      "required": [
        "target"
      ]
    },
    "defang:index:PostgresConfig": {
      "properties": {
        "allowBurstable": {
          "type": "boolean"
        },
        "availabilityType": {
          "type": "string"
        },
        "backupEnabled": {
          "type": "boolean"
        },
        "dbName": {
          "type": "string"
        },
        "deletionProtection": {
          "type": "boolean"
        },
        "password": {
          "type": "string"
        },
        "pointInTimeRecovery": {
          "type": "boolean"
        },
        "sslMode": {
          "type": "string"
        },
        "username": {
          "type": "string"
        },
        "version": {
          "type": "integer"
        }
      },
      "type": "object",
      "required": [
        "password"
      ]
    },
    "defang:index:ResourceConfig": {
      "properties": {
        "cpus": {
          "type": "number"
        },
        "memory": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "defang:index:ResourcesConfig": {
      "properties": {
        "limits": {
          "$ref": "#/types/defang:index:ResourceConfig"
        },
        "reservations": {
          "$ref": "#/types/defang:index:ResourceConfig"
        }
      },
      "type": "object"
    },
    "defang:index:ServiceInput": {
      "properties": {
        "cloudRun": {
          "$ref": "#/types/defang:index:CloudRunConfig"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "deploy": {
          "$ref": "#/types/defang:index:DeployConfig"
        },
        "domainName": {
          "type": "string"
        },
        "entrypoint": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "healthCheck": {
          "$ref": "#/types/defang:index:HealthCheckConfig"
        },
        "image": {
          "type": "string"
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/types/defang:index:PortConfig"
          }
        },
        "postgres": {
          "$ref": "#/types/defang:index:PostgresConfig"
        }
      },
      "type": "object"
    }
  },
  "provider": {},
  "resources": {
    "defang:index:Project": {
      "properties": {
        "endpoints": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "plain": true
          }
        },
        "loadBalancerDns": {
          "type": "string"
        }
      },
      "required": [
        "endpoints"
      ],
      "inputProperties": {
        "aws": {
          "$ref": "#/types/defang:index:AWSConfigInput"
        },
        "gcp": {
          "$ref": "#/types/defang:index:GCPConfigInput"
        },
        "providerId": {
          "type": "string",
          "plain": true
        },
        "services": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/types/defang:index:ServiceInput"
          }
        }
      },
      "requiredInputs": [
        "providerId",
        "services"
      ],
      "isComponent": true
    },
    "defang:index:Service": {
      "properties": {
        "endpoint": {
          "type": "string"
        }
      },
      "required": [
        "endpoint"
      ],
      "inputProperties": {
        "cloudRun": {
          "$ref": "#/types/defang:index:CloudRunConfig"
        },
        "command": {
          "type": "array",
          "items": {
            "type": "string",
            "plain": true
          }
        },
        "deploy": {
          "$ref": "#/types/defang:index:DeployConfig"
        },
        "domainName": {
          "type": "string",
          "plain": true
        },
        "entrypoint": {
          "type": "array",
          "items": {
            "type": "string",
            "plain": true
          }
        },
        "environment": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "plain": true
          }
        },
        "healthCheck": {
          "$ref": "#/types/defang:index:HealthCheckConfig"
        },
        "image": {
          "type": "string",
          "plain": true
        },
        "ports": {
          "type": "array",
          "items": {
            "$ref": "#/types/defang:index:PortConfig"
          }
        },
        "postgres": {
          "$ref": "#/types/defang:index:PostgresConfig"
        },
        "providerId": {
          "type": "string",
          "plain": true
        }
      },
      "requiredInputs": [
        "providerId"
      ],
      "isComponent": true
    }
  }
}
